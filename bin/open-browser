#!/bin/sh

# Launch default browser.

usage() {
  cat <<'EOF'
Launch default browser.

Usage: open-browser [-h]

Options:
  -h    Show help

Browserctl is required on MacOS.
EOF
}

OPTSTRING=":h"
while getopts "$OPTSTRING" opt; do
  case $opt in
  h)
    usage
    exit 0
    ;;
  \?)
    echo "Unknown option: -$OPTARG" >&2
    exit 1
    ;;
  esac
done

shift $((OPTIND - 1))

OS=$(uname -s)

case $OS in
Darwin)
  if ! command -v browserctl >/dev/null 2>&1; then
    echo "Error: browserctl not installed"
    exit 1
  fi
  open -a "$(browserctl get --name-only)"
  ;;
Linux)
  echo "Error: not implemented yet"
  exit 1
  ;;
*)
  echo "Error: unsupported operating system: $OS"
  exit 1
  ;;
esac
