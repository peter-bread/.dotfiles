#!/usr/bin/env bash
#
# This is a standalone script designed to bootstrap a MacOS or Linux machine.
# Handles "normal" systems, so NixOS and nix-darwin are not supported, though
# maybe they will be one day.
#
# It reads from declarative MANIFEST files, which desrcribe what modules and
# packages should be installed on a system.
#
# ==============================================================================
# =================== GENERAL INFORMATION FOR MAINTENANCE ======================
# ==============================================================================
#
# Documentation is inspired by Google's Bash style guide.
# See 'https://google.github.io/styleguide/shellguide.html'.
#
# Introduction -----------------------------------------------------------------
#
# This script MUST be COMPATIBLE with Bash 3.2. This is because MacOS ships
# with this version by default (though newer versions can be installed via
# Homebrew). However, this script will likely be run with the default version,
# so that is what should be targeted. In practice, this just means that
# certain, newer features can't be used, namely: associative arrays, mapfile,
# readarray and globstar.
#
# Arguments and Options --------------------------------------------------------
#
# Positional arguments are stored in the ARGS array. The number of arguments
# that should be provided is stored in the EXPECTED_ARGS variable.
#
# Options come in two forms, option flags and option arguments.
#
# An option flag is a toggle, i.e. it is either enabled (1) or disabled (0).
# Option flags can be checked using the `flag` function.
#
# An option argument also toggles behaviour, but also accepts a single argument.
# The value of this argument can be checked using the `flag_arg` function.
#
# Error Handling ---------------------------------------------------------------
#
# Using `set -e` causes the script to terminate on any unhandled, non-zero exit
# code.
#
# Handled errors:
#
#   # Handle with an `if` (useful when mutiple steps are required).
#   if false; then
#     fallback
#     then_do_this
#     and_then_this
#   fi
#
#   # Handle with a `||` (useful when a single step suffices).
#   false || fallback
#
# Unhandled errors (triggers exit):
#
#   # Unhandled, caught by `set -e`.
#   false
#
# The `error` function logs a custom message, then itself returns 1. We can use
# it as the fallback for a handled error, then let `set -e` exit:
#
#   false || error "Something went wrong"
#
# This should be the main method used to exit this script in case of an error.
#
# ------------------------------------------------------------------------------

set -Eeuo pipefail

################################################################################
# GLOBALS
################################################################################

# Raw information for logging purposes.
readonly SCRIPT_NAME="$0"
readonly SCRIPT_ARGS=("$@")

# TODO: Export this?
# TODO: Make DOTFILES readonly?
DOTFILES="$HOME/.dotfiles"

# TODO: Convert to lowercase (remember to modify checks whenever these are used)?
# Get system info.
OS=$(uname -s)
ARCH=$(uname -m)

# POSITIONAL ARGUMENTS
EXPECTED_ARGS=0
ARGS=()

# OPTIONS
: "${PRIME:=0}"
: "${MODULES:=0}"
: "${PKGS:=0}"
: "${GITHUB:=0}"

# OPTION ARGUMENTS
: "${NVIM:=}"

# Developer Options
: "${DEV_USE_LOCAL:=0}"
: "${DEV_USE_TEST:=0}"

################################################################################
# WARNING! THE FOLLOWING CODE IS AUTOMATICALLY INJECTED ########################
################################################################################
### BEGIN HELPERS ###

# Logging options.
: "${ENABLE_COLOR:=1}" # 1 = colored output,      0 = plain
: "${ENABLE_DEBUG:=0}" # 1 = show debug messages, 0 = hide
DATE_FORMAT="%Y-%m-%d %H:%M:%S"

# ANSI color codes.
RESET="\e[0m"
RED="\e[31m"
GREEN="\e[32m"
YELLOW="\e[33m"
BLUE="\e[34m"
CYAN="\e[36m"

################################################################################
# LOGGING
################################################################################

########################################
# Internal logging function. Should not be called directly. See wrappers below.
# Globals:
#   DATE_FORMAT
#   ENABLE_COLOR
#   RESET
# Arguments:
#   Log level, a string, all caps.
#   Message to be logged.
#   Color to be used, ANSI escape sequence.
#   (Optional) File descriptor to write to, an integer. Defaults to 1 (stdout).
# Outputs:
#   Writes message to file descriptor.
########################################
_log() {
  local level=$1
  local msg=$2
  local color=$3
  local fd=${4:-1}
  local timestamp
  timestamp=$(date +"$DATE_FORMAT")

  if [[ $ENABLE_COLOR -eq 1 && -n "$color" ]]; then
    printf "%s ${color}[%-7s]${RESET} %s\n" "$timestamp" "$level" "$msg" >&"$fd"
  else
    printf "%s [%-7s] %s\n" "$timestamp" "$level" "$msg" >&"$fd"
  fi
}

########################################
# Write an information message to stdout.
# Globals:
#   BLUE
# Arguments:
#   Message to be logged.
# Outputs:
#   Writes message to stdout.
########################################
info() { _log "INFO" "$1" "$BLUE"; }

########################################
# Write a warning message to stderr.
# Globals:
#   YELLOW
# Arguments:
#   Message to be logged.
# Outputs:
#   Writes message to stderr.
########################################
warn() { _log "WARN" "$1" "$YELLOW" 2; }

########################################
# Write an error message to stderr. This should be used when an unrecoverable
# error occurs and execution should terminate.
# Globals:
#   RED
# Arguments:
#   Message to be logged.
# Outputs:
#   Writes message to stderr.
# Returns:
#   1 to indicate that an error has occurred.
# Examples:
#   # Log an error
#   foo || error "Foo failed"
#
#   # Print multiline error
#   error "Line 1" || true
#   error "Line 2" || true
#   error "Line 3"
########################################
error() {
  _log "ERROR" "$1" "$RED" 2
  return 1
}

########################################
# Write a success message to stdout.
# Globals:
#   GREEN
# Arguments:
#   Message to be logged.
# Outputs:
#   Writes message to stdout.
########################################
success() { _log "SUCCESS" "$1" "$GREEN"; }

########################################
# Write a debug message to stderr if ENABLE_DEBUG=1.
# Globals:
#   ENABLE_DEBUG
#   CYAN
# Arguments:
#   Message to be logged.
# Outputs:
#   Writes message to stderr if ENABLE_DEBUG=1.
########################################
debug() { if [[ $ENABLE_DEBUG -eq 1 ]]; then _log "DEBUG" "$1" "$CYAN" 2; fi; }

########################################
# Check if a command exists.
# Arguments:
#   Command to check.
# Returns:
#   0 if command exists, 1 otherwise.
########################################
available() {
  command -v -- "$1" &>/dev/null
}

########################################
# Check if a command does not exist.
# Arguments:
#   Command to check.
# Returns:
#   0 if command does not exist, 1 otherwise.
########################################
unavailable() {
  ! available "$1"
}

########################################
# Check if a command exists and log an error if it does not.
# Use this when a command not existing is an unrecoverable error.
# Ensure `set -e` is enabled otherwise you are respobsible for exiting if this
# function returns 1.
# Arguments:
#   Command to check.
# Outputs:
#   Message to stderr if command does not exist.
# Returns:
#   0 if command exists, 1 otherwise.
########################################
need() {
  local cmd=$1

  available "$cmd" || error "Needs $cmd"
}

########################################
# Check if any of a list of commands exists.
# Arguments:
#   Commands to check.
# Outputs:
#   First command that exists to stdout if a command does exist.
#   Message to stderr if none of the commands exist.
# Returns:
#   0 if a command exists, 1 if none exist.
########################################
need_any() {
  local cmds=("$@")

  for cmd in "${cmds[@]}"; do
    if available "$cmd"; then
      echo "$cmd"
      return 0
    fi
  done

  error "Needs one of: ${cmds[*]}"
}

########################################
# Check if all of a list of commands exists.
# Arguments:
#   Commands to check.
# Outputs:
#   Message to stderr if reported any missing commands.
# Returns:
#   0 if all commands exist, 1 if any do not exist.
########################################
need_all() {
  local cmds=("$@")
  local missing=()

  for cmd in "${cmds[@]}"; do
    available "$cmd" || missing+=("$cmd")
  done

  if ((${#missing[@]})); then
    error "Missing required commands: ${missing[*]}"
  fi

  return 0
}

########################################
# Given a list of commands, report which ones are available and which are
# missing.
# Arguments:
#   Commands to check.
# Outputs:
#   Reports found and missing commands to stderr.
# Returns:
#   0.
########################################
check_tools() {
  local found=()
  local missing=()

  for cmd in "$@"; do
    if available "$cmd"; then
      found+=("$cmd")
    else
      missing+=("$cmd")
    fi
  done

  if ((${#found[@]})); then
    debug "Available: ${found[*]}"
  fi

  if ((${#missing[@]})); then
    warn "Unavailable: ${missing[*]}"
  fi

  return 0
}

########################################
# Check if a file is a regular executable file.
# Arguments:
#   File to check, a path.
# Returns:
#   0 if file is a regular executable file, 1 otherwise.
########################################
is_executable_file() {
  local file=$1

  [[ -f $file && -x $file ]]
}

########################################
# Check if current OS is MacOS.
# Returns:
#   0 if on MacOS, 1 otherwise.
########################################
is_macos() {
  [[ $(uname -s) == *Darwin* ]]
}

########################################
# Check if current OS is Linux.
# Returns:
#   0 if on Linux, 1 otherwise.
########################################
is_linux() {
  [[ $(uname -s) == *Linux* ]]
}

########################################
# Replace a file with another file only if they are different.
# Arguments:
#   Source file to copy.
#   Destination file to be overwritten.
#   (Optional) Message to print if src and dst are the same.
########################################
install_if_different() {
  local src=$1
  local dst=$2
  local msg=${3:-Files are the same; no changes to be made}

  if cmp -s "$src" "$dst"; then
    debug "$msg"
  else
    mkdir -p "$(dirname "$dst")"
    mv "$src" "$dst"
  fi
}

### END HELPERS ###
################################################################################
# WARNING! THE ABOVE CODE IS AUTOMATICALLY INJECTED ############################
################################################################################

########################################
# Print help and exit immediately.
# Outputs:
#   Help message to stdout.
# Returns:
#   0.
########################################
show_help() {
  cat <<'EOF'
Bootstrap script.

Without any options provided, this script will check if required tools are
installed and will then clone or pull dotfiles repository to ~/.dotfiles.

Options can be provided to enable extra functionality.

Usage:
  ./install [-P] [-m] [-p] [-g] [-n <repo>] [-h]

Options:
  -P          Prime system to ensure system has required packages installed.
  -m          Install modules from MANIFEST.* files.
  -p          Install packages from MANIFEST.* files.
  -g          Authenticate with GitHub on this device.
  -n <repo>   Clone Neovim config as specified by <repo>.
              <repo> can be one of three forms:
                - A short name (e.g. "peter.nvim"), resolved as:
                    https://github.com/peter-bread/<repo>.git
                - A full "owner/repo" pair (e.g. "someone/other.nvim"), resolved as:
                    https://github.com/<repo>.git
                - A full Git URL (e.g. "https://github.com/user/repo.git"), HTTPS or SSH, used as-is
  -h          Print this help message.

Environment Variables:
  These variables mirror the options above. Flags provided on the command line
  take precedence over environment variables. All boolean variables default to 0
  (disabled) unless otherwise noted.

  Option Flags (0 = disable, 1 = enable):
    PRIME       -P
    MODULES     -m
    PKGS        -p
    GITHUB      -g

  Option Arguments (string; default = empty):
    NVIM        -n <repo>

  Logging and Output:
    ENABLE_COLOR  Enable colored logging output (default: 1)
    ENABLE_DEBUG  Enable debug logging (default: 0)

  Developer / Advanced:
    DEV_USE_LOCAL   Developer mode: do not attempt to clone/pull dotfiles repo.
                    Useful when testing WIP scripts in a Docker container.
    DEV_USE_TEST    Developer mode: only use MANIFEST.test.
EOF
  exit 0
}

########################################
# Parse command line arguments and options.
# Globals:
#   PRIME
#   MODULES
#   PKGS
#   GITHUB
#   NVIM
#   ARGS
#   EXPECTED_ARGS
# Arguments:
#   All arguments passed to the script.
# Outputs:
#   Writes error mesages to stderr.
#   Writes help message to stdout (if -h is provided).
# Returns:
#   0 if arguments are parsed successfully, 1 otherwise.
########################################
parse_args() {

  while getopts ":Pmpgn:h" opt; do
    case $opt in
    P) PRIME=1 ;;
    m) MODULES=1 ;;
    p) PKGS=1 ;;
    g) GITHUB=1 ;;
    n) NVIM=$OPTARG ;;
    h) show_help ;;
    :) error "-$OPTARG requires a value" ;;
    \?) error "Unknown option: -$OPTARG" ;;
    esac
  done

  shift $((OPTIND - 1))

  debug "Options parsed"
  debug "PRIME=$PRIME"
  debug "MODULES=$MODULES"
  debug "PKGS=$PKGS"
  debug "GITHUB=$GITHUB"
  debug "NVIM=$NVIM"

  ARGS+=("$@")

  if [[ ${#ARGS[@]} -lt $EXPECTED_ARGS ]]; then
    error "Expected $((EXPECTED_ARGS - ${#ARGS[@]})) more argument(s)"
  fi

  if [[ ${#ARGS[@]} -gt $EXPECTED_ARGS ]]; then
    error "Unexpected extra positional arguments: ${ARGS[*]:$((EXPECTED_ARGS))}"
  fi

}

########################################
# Check if an option flag is enabled (set to 1).
# Globals:
#   PRIME
#   MODULES
#   PKGS
#   GITHUB
# Arguments:
#   Option flag.
# Returns:
#   0 if flag is enabled, 1 otherwise.
########################################
flag() {
  [[ $1 -eq 1 ]]
}

########################################
# Check if an option argument is provided (non empty or unset).
# Globals:
#   NVIM
# Arguments:
#   Option argument.
# Returns:
#   0 if argument is given, 1 otherwise.
########################################
flag_arg() {
  [[ -n $1 ]]
}

########################################
# Prime the system so it is in a state where the main bootstrapping process can
# begin.
#
# Since MacOS ships with Bash 3.2, this section must be compatible with that
# and must not use newer Bash features.
#
# This essentially boils down to making sure a few essential packages are
# installed:
# - git
# - python3
# - curl/wget
# - tar/unzip/bzip2/xz
#
# For MacOS it is a bit more involved as some of these things are not available
# OOTB, and there isn't even a builtin package manager.
#
# For Linux, it should just be a case of determining which package manager to
# use and then installing the software.
#
# Globals:
#   OS
#   ARCH
#
# Returns:
#   0 if system primes successfully, 1 otherwise.
########################################
prime() {

  ########################################
  # Prime a MacOS system.
  # Installs Xcode Command Line Tools and Homebrew package manager.
  #
  # Globals:
  #   OS
  #   ARCH
  ########################################
  prime::macos() {
    info "Priming MacOS..."

    case $ARCH in
    *arm*) PREFIX=/opt/homebrew ;;
    *x86_64*) PREFIX=/usr/local ;; # TODO: Realistically I can drop support for Intel Macs.
    *) error "$ARCH CPU architecture is not supported" ;;
    esac

    debug "OS    : $OS"
    debug "ARCH  : $ARCH"
    debug "PREFIX: $PREFIX"

    info "Checking if Homebrew is already installed..."

    # TODO: Is letting Homebrew install command line tools the best approach or
    # should it be done manually?

    if unavailable "$PREFIX"/bin/brew; then
      warn "Homebrew not installed"
      info "Installing Homebrew. This will also install Xcode Command Line Tools if required..."
      if ! /bin/bash -c \
        "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"; then
        error "Homebrew installation failed"
      fi
    fi

    info "Homebrew already installed"

    debug "Checking if brew is in PATH"

    if unavailable brew; then
      debug "brew is not in PATH"
      info "Adding brew to PATH..."
      eval "$("$PREFIX"/bin/brew shellenv)"
    fi

    debug "brew is in PATH"

    # Default: curl bzip2 tar unzip
    # Xcode Command Line Tools: git python3

    brew update
    # brew upgrade
    brew install \
      wget \
      xz \
      gh

    success "MacOS primed"
  }

  ########################################
  # Prime a Linux system. Determine Linix distro and install necessary packages.
  ########################################
  prime::linux() {
    # TODO: Fallback to checking known package managers.
    [[ -f /etc/os-release ]] || error "Couldn't determine Linux distro as /etc/os-release does not exist"

    prime::linux::apt() {
      sudo apt-get update
      sudo apt-get upgrade -y
      sudo apt-get install -y \
        git python3 \
        curl wget \
        tar unzip bzip2 xz-utils

      # Install latest version of GitHub CLI.
      (type -p wget >/dev/null || (sudo apt update && sudo apt install wget -y)) &&
        sudo mkdir -p -m 755 /etc/apt/keyrings &&
        out=$(mktemp) && wget -nv -O"$out" https://cli.github.com/packages/githubcli-archive-keyring.gpg &&
        cat "$out" | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg >/dev/null &&
        sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg &&
        sudo mkdir -p -m 755 /etc/apt/sources.list.d &&
        echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null &&
        sudo apt update &&
        sudo apt install gh -y
    }

    prime::linux::dnf() {
      error "TODO: Implement dnf"
    }

    prime::linux::pacman() {
      error "TODO: Implement pacman"
    }

    prime::linux::apk() {
      error "TODO: Implement apk"
    }

    prime::linux::xbps() {
      error "TODO: Implement xbps"
    }

    # Load all data about OS into environment variables. This is clean and
    # avoids any weird parsing.
    #
    # shellcheck disable=SC1091
    # This file never exists on MacOS and the warning is annoying.
    . /etc/os-release

    # This is mainly for package managers. While it would probably make sense
    # to use ID_LIKE, this is an optional field in the systemd specification.
    # Therefore it is safer to just hardcode distros and use ID instead.
    # See 'https://www.freedesktop.org/software/systemd/man/latest/os-release.html#ID_LIKE='.
    #
    # It would be possible to combine ID and ID_LIKE:
    #
    #   case $ID:$ID_LIKE in
    #   ubuntu:* | debian:* | *:debian) prime::linux::apt ;;
    #   esac

    # TODO: Maybe check known package managers as well or instead?
    case $ID in
    ubuntu | debian) prime::linux::apt ;;
    fedora) prime::linux::dnf ;;
    arch) prime::linux::pacman ;;
    alpine) prime::linux::apk ;;
    void) prime::linux::xbps ;;
    *) error "Unsupported distro: $ID" ;;
    esac

    success "Linux primed"
  }

  case $OS in
  Darwin) prime::macos ;;
  Linux) prime::linux ;;
  esac

  success "System primed"
}

# TODO: Including checking requirements under prime option?
check_requirements() {

  info "Checking required tools are available..."

  # Required.
  need_all git python3 gh

  # At least one downloader.
  need_any curl wget &>/dev/null

  # Optional archive tools.
  check_tools tar unzip xz bzip2

  success "All essential tools are installed"
}

setup_dotfiles_repo() {
  if [[ -d $DOTFILES ]]; then

    info "Dotfiles already exist locally at $DOTFILES"
    info "Pulling latest changes..."

    local before
    before=$(git -C "$DOTFILES" rev-parse HEAD)

    # TODO: Should this be a rebase?
    # git -C "$DOTFILES" pull --rebase
    git -C "$DOTFILES" pull || error "Pulling latest changes failed"

    success "Dotfiles repo updated"

    local after
    after=$(git -C "$DOTFILES" rev-parse HEAD)

    if [[ $before != "$after" ]]; then
      info "Repo updated, re-executing install script..."
      exec "$DOTFILES/install" "$@"
    fi

  else

    local url="https://github.com/peter-bread/.dotfiles.git"

    info "Dotfiles do not exist locally at $DOTFILES"
    info "Cloning $url into $DOTFILES"

    git clone --branch=main "$url" "$DOTFILES" || error "Cloning dotfiles failed"

    success "Dotfiles repo cloned"

  fi

  success "Dotfiles repo setup"
}

install_module() {
  local module=$1

  local module_dir="$DOTFILES/${module}"
  local module_install="$module_dir/install"

  [[ -d $module_dir ]] || error "$module module does not exist"

  # If the module exists but has no install script, it is likely a
  # "special" module. In this case, documentation should be consulted.
  if [[ ! -f $module_install ]]; then
    warn "$module module does not contain an install script. Skipping..."
    return
  fi

  if [[ ! -x $module_install ]]; then
    warn "$module module contains a non-executable install script. Skipping..."
    return
  fi

  info "Installing $module module..."

  "$module_install" || error "Failed to install $module module"

  success "Installed $module module"
}

install_package_manual() {
  local package=$1
  local dir=$DOTFILES/packages/manual/$package

  info "Installing $package package"

  [[ -d $dir ]] || error "$dir is not a directory"

  local install=$dir/install
  local postinstall=$dir/postinstall
  local completions=$dir/completions

  local did_install=0

  local run_count=0
  local total=3

  # TODO: Improve logging and general structure.

  run_step() {
    local file=$1

    debug "Running $file"
    "$file" || error "Failed to run $file"
    # WARN: If (( expr )) evaluates to 0, ERR trap is triggered.
    # Using pre-increment means it will always be incremented above 0 before it
    # is evaluated. If this every could evaluate to 0, use:
    #   run_count=$((run_count + 1))
    # instead.
    ((++run_count))
    debug "Ran $file"
  }

  if is_executable_file "$install"; then
    run_step "$install"
    did_install=1
  else
    debug "Skipping $install"
  fi

  # Postinstall only runs if install runs successfully.
  if [[ $did_install -eq 1 ]] && is_executable_file "$postinstall"; then
    run_step "$postinstall"
  else
    debug "Skipping $postinstall"
  fi

  if is_executable_file "$completions"; then
    run_step "$completions"
  else
    debug "Skipping $completions"
  fi

  if ((run_count == 0)); then
    warn "Nothing to install: $run_count/$total scripts were run for $package package installation"
  else
    success "Installed $package package (ran $run_count/$total scripts)"
  fi
}

install_package_brew() {
  local brewfile=$1
  local dir=$DOTFILES/packages/brew

  info "Installing packages from $dir/$brewfile"

  # TODO: Should this use `--upgrade` or `--no-upgrade` flag?
  # By default, packages *are* upgraded.
  brew bundle --file="$dir/$brewfile" --verbose || error "Brewfile installation failed"

  success "Installed packages from $dir/$brewfile"
}

install_package() {
  local package=$1

  case $package in
  manual/*) install_package_manual "${package#manual/}" ;;
  brew/*) install_package_brew "${package#brew/}" ;;
  *) warn "Unknown package format: $package" ;;
  esac
}

install_from_manifest() {
  local manifest=$1
  local mode=$2

  info "Installing $mode from $manifest"

  [[ -f $manifest ]] || error "$manifest does not exist"

  while IFS= read -r item; do
    [[ -n $item && $item != \#* ]] || continue

    case $mode:$item in
    modules:mod:*) install_module "${item#mod:}" ;;
    packages:pkg:*) install_package "${item#pkg:}" ;;
    modules:* | packages:*) debug "Skipping $item in $mode mode" ;;
    *) warn "Unknown: $item" ;;
    esac

  done <"$manifest"

  success "Installed $mode from $manifest"
}

install_from_all_manifests() {
  local mode=$1

  # Don't validate $mode here; let install_from_manifest error.

  # Use MANIFEST.test instead of other MANIFEST files for testing purposes.
  if flag "$DEV_USE_TEST"; then
    debug "DEV_USE_TEST is a Developer-only option"
    debug "Only MANIFEST.test will be used"
    debug "All other MANIFEST.* files will be ignored"
    install_from_manifest "$DOTFILES"/MANIFEST.test "$mode"
    return
  fi

  install_from_manifest "$DOTFILES"/MANIFEST.common "$mode"

  case $OS in
  Darwin) install_from_manifest "$DOTFILES"/MANIFEST.macos "$mode" ;;
  Linux) install_from_manifest "$DOTFILES"/MANIFEST.linux "$mode" ;;
  # TODO: Use /etc/os-release or package manager for distro-specific manifests?
  esac
}

install_modules() {
  install_from_all_manifests modules
}

install_pkgs() {
  install_from_all_manifests packages
}

setup_personal_github() {
  local account="peter-bread"
  local category="personal"

  # TODO: Add logging.

  # --github-auth (and --add-keys, but this is because it depends on the other flag)
  # requires manual intervention to copy and paste codes into a browser. This means
  # it cannot be used in a headless environment.

  ./bin/setup-github-account "$account" \
    --category "$category" \
    --base-dir "${DEVELOPER:-$HOME/Developer}" \
    --email "145384599+peter-bread@users.noreply.github.com" \
    --allowed-signers \
    --gen-keys \
    --github-auth \
    --add-keys
}

setup_neovim() {

  info "Downloading Neovim config..."

  is_full_url() {
    local input="$1"
    [[ "$input" =~ ^(https://|git@) ]]
  }

  local input="$NVIM"
  local url

  if is_full_url "$input"; then
    url="$input"
  elif [[ "$input" == */* ]]; then
    url="https://github.com/$input"
  else
    url="https://github.com/peter-bread/$input"
  fi

  if [[ $url != *.git ]]; then
    url="${url}.git"
  fi

  info "Resolved Neovim Git repository URL: $url"

  repo="${url##*/}"
  repo="${repo%.git}"

  info "Resolved Neovim Git repository name: $repo"

  dir="${XDG_CONFIG_HOME:-$HOME/.config}/$repo"

  info "Resolved Neovim install location: $dir"

  if [[ -d $dir ]]; then

    info "$dir already exists"
    info "Pulling latest changes..."

    git -C "$dir" pull || error "Pulling latest changes failed"

    success "Neovim config updated"

  else

    info "$dir does not exist"

    # We set GIT_TERMINAL_PROMPT=0 so if authentication fails the user will not
    # be prompted to enter their credentials.
    #
    # This means the Git repository containing the Neovim configuration must
    # either be public, or private with the current user already having Git
    # authentication set up.
    #
    export GIT_TERMINAL_PROMPT=0

    info "Checking if $url is an accessible Git repository"

    git ls-remote "$url" &>/dev/null || error "Git repository $url: no access or does not exist"

    info "Cloning $url into $dir"

    git clone --branch=main "$url" "$dir" || error "Cloning neovim config failed"

    unset -v GIT_TERMINAL_PROMPT

    success "Neovim config ($repo) cloned"

  fi

  if unavailable nvim; then
    warn "Neovim not installed"
    warn "Skipping headless setup"
    return
  fi

  local nvim_install_script=$dir/scripts/install

  info "Attempting Neovim headless setup..."

  if [[ ! -x $nvim_install_script ]]; then
    warn "Neovim headless installation script could not be found"
    warn "Skipping headless setup"
    return
  fi

  "$nvim_install_script" || error "Neovim headless setup failed"

  success "Neovim headless setup successful"
}

final_message() {
  local status=$1
  local msg=""

  msg+="$SCRIPT_NAME"
  ((${#SCRIPT_ARGS[@]})) && msg+=" ${SCRIPT_ARGS[*]}"
  msg+=" $status"

  echo "$msg"
}

main() {
  parse_args "$@"

  flag "$PRIME" && prime

  check_requirements

  # Skip pulling changes if testing local development version.
  if flag "$DEV_USE_LOCAL"; then
    debug "DEV_USE_LOCAL is a Developer-only option"
    debug "Skipping dotfiles repo setup"
    debug "Assuming local dotfiles repo exists"
  else
    setup_dotfiles_repo "$@"
  fi

  cd "$DOTFILES" || error "Could not cd into $DOTFILES"

  # Export shell-agnostic, non-interactive environment variables.
  source "$DOTFILES"/env/non-interactive

  flag "$MODULES" && install_modules

  flag "$PKGS" && install_pkgs

  flag "$GITHUB" && setup_personal_github

  flag_arg "$NVIM" && setup_neovim

  success "$(final_message completed)"
}

error_handler() {
  local exit_code=$?
  local cmd="$BASH_COMMAND"
  local script="${BASH_SOURCE[0]}"
  local abs_script

  abs_script="$(cd "$(dirname "$script")" && pwd)/$(basename "$script")"

  printf "\n"
  printf "============================== ERROR REPORT ==============================\n"

  printf "Summary:\n"
  printf "  Command:   %s\n" "$cmd"
  printf "  Exit code: %s\n" "$exit_code"
  printf "\n"

  printf "Location:\n"
  printf "  Script: %s\n" "$abs_script"
  printf "  File:   %s\n" "${BASH_SOURCE[1]}"
  printf "  Line:   %s\n" "${BASH_LINENO[0]}"
  printf "\n"

  printf "Stack trace:\n"

  for i in "${!FUNCNAME[@]}"; do
    [[ $i -eq 0 ]] && continue

    local func="${FUNCNAME[$i]}"
    local file="${BASH_SOURCE[$i]}"
    local line="${BASH_LINENO[$((i - 1))]}"

    printf "  at %s (%s:%s)\n" \
      "${func:-MAIN}" \
      "$file" \
      "${line:-?}"
  done

  printf "==========================================================================\n"

  printf "\n"
  error "$(final_message failed)"
}

trap error_handler ERR

main "$@"
