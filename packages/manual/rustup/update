#!/usr/bin/env bash

# Update Rustup:
# - Updates all installed toochains
# - Updates rustup itself

set -Eeuo pipefail

source "$DOTFILES"/_helpers/core

info "Updating Rustup"

need "$HOME"/.cargo/bin/rustup

if ! "$HOME"/.cargo/bin/rustup update; then
  error "rustup failed to update"
  exit 1
fi

success "Rustup updated"
