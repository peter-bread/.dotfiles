#!/usr/bin/env bash

# Update GHCup:
# - Updates GHCup
# - Does NOT make any changes to tools installed via GHCup

set -Eeuo pipefail

source "$DOTFILES"/_helpers/core

# shellcheck source=./packages/manual/ghcup/env
. /dev/null

info "Updating GHCup"

need "$GHCUP"

if ! "$GHCUP" upgrade; then
  error "ghcup failed to update"
  exit 1
fi

success "GHCup updated"
