#!/usr/bin/env bash

set -Eeuo pipefail

source "${DOTFILES:?}"/_helpers/core

need_all git swift make install mktemp dirname

TMP=$(mktemp -d) || error "Failed to create temporary directory"
trap 'rm -rf "$TMP"' EXIT

REPO_URL=https://github.com/peter-bread/browserctl
BUILD_DIR=$TMP/browserctl
PREFIX=$HOME/.local

git clone --depth=1 "$REPO_URL" "$BUILD_DIR"
cd "$BUILD_DIR"
make release || error "Build failed"
make install PREFIX="$PREFIX" || error "Installation failed"

# Test
[[ -x $PREFIX/bin/browserctl ]] || error "Could not find executable at $PREFIX/bin/browserctl"

success "Browserctl installed"
