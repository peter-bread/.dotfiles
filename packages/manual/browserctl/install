#!/usr/bin/env bash

set -Eeuo pipefail

source "${DOTFILES:?}"/_helpers/core

warn "This script ($0) is unfinished"

need_all git swift make install mktemp dirname

TMP=$(mktemp -d) || error "Failed to create temporary directory"
trap 'rm -rf "$TMP"' EXIT

REPO_URL=https://github.com/peter-bread/browserctl
BUILD_DIR=$TMP/browserctl
BIN_PATH=$BUILD_DIR/.build/release/browserctl
DEST=$HOME/.local/bin/browserctl

git clone --depth=1 "$REPO_URL" "$BUILD_DIR"

make -C "$BUILD_DIR" release || error "Build failed"

[[ -x "$BIN_PATH" ]] || error "Build succeeded but binary not found at $BIN_PATH"

# TODO: Remove echo.
warn "TODO: Remove echo from following lines to actually run commands"
echo mkdir -p "$(dirname "$DEST")"
echo install -m 0755 "$BIN_PATH" "$DEST"
